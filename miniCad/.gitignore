# .gitignore for miniCad
# 保留源码和配置文件；忽略构建产物、IDE 配置和临时文件，便于别人拉取后直接编译

########################
# Project files to keep
########################
# 保留：项目源码、头文件、测试和 CMake 配置
!CMakeLists.txt
!CMakePresets.json
!README.md
!LICENSE
!include/
!include/**
!src/
!src/**
!tests/
!tests/**

########################
# Build and generated files
########################
# CMake and build outputs
cmake-build-debug-build/
build/
bin/
out/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
build.ninja
rules.ninja
*.ninja

# Generated by IDEs or CMake (Qt autogen etc.)
miniCad_autogen/
*.moc
mocs_compilation.cpp
autogen/

# Object files, libraries, executables
*.o
*.obj
*.lo
*.la
*.a
*.lib
*.so
*.dylib
*.dll
*.exe
*.out
*.ilk
*.pdb

########################
# IDEs, editors
########################
.vscode/
.idea/
*.iml
*.suo
*.user
*.vcxproj*
*.db

########################
# Logs, temp, backup
########################
*.log
*.tmp
*.temp
*.swp
*~
*.bak
*.backup

########################
# OS files
########################
.DS_Store
Thumbs.db

########################
# Coverage / profiling
########################
coverage/
*.gcda
*.gcno
*.gcov

########################
# Packages
########################
# Python
__pycache__/
*.py[cod]

# Node
node_modules/

# Misc
*.orig
